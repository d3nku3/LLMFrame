  "universal_checks": {
    "output_contract_tag": {
      "token": "<OUTPUT_CONTRACT>",
      "severity_if_missing": "warn"
    },
    "minimum_length": {
      "threshold_chars": 1500,
      "severity_if_below": "warn"
    },
    "residual_domain_markers": {
      "pattern": "\\[DOMAIN:[^\\]]*\\]",
      "severity_if_found": "fail"
    }
  },
  "escalation_patterns": {
    "description": "v5 prompts use varying vocabulary for escalation/blocked-state routing. The validator accepts any of these patterns.",
    "patterns": [
      {
        "name": "classic_escalation",
        "regex": "escalat",
        "second": "architect|upstream",
        "flags": "i"
      },
      {
        "name": "blocked_state",
        "regex": "blocked.state",
        "flags": "i"
      },
      {
        "name": "contract_spec_issue",
        "regex": "contract\\s*/\\s*spec\\s*issue",
        "flags": "i"
      },
      {
        "name": "upstream_blockers",
        "regex": "blockers?\\s+requiring\\s+upstream",
        "flags": "i"
      }
    ]
  },
  "greeting_patterns": {
    "sentence_patterns": [
      "When the conversation begins",
      "Begin the conversation exactly"
    ],
    "required_tag": "DO_NOT_BREAK"
  },
  "agnostic_notes": {
    "role_name_mapping": {
      "stage4": {
        "protocol": "Module Implementer",
        "agnostic": "Deliverable Author"
      },
      "stage5": {
        "protocol": "Code Reviewer",
        "agnostic": "Deliverable Reviewer"
      },
      "stage6": {
        "protocol": "Integration Coordinator",
        "agnostic": "Integration Coordinator"
      }
    },
    "frozen_tokens_absent_in_agnostic": {
      "stage1": {
        "tokens": [
          "CRITICAL_RULE"
        ],
        "reason": "Domain-specific enforcement marker"
      },
      "stage4": {
        "tokens": [
          "Definition of Done",
          "Not-Done-If",
          "Boundary Verification Status"
        ],
        "reason": "Domain-specific output sections"
      },
      "stage5": {
        "tokens": [
          "Merge-Blocking: NO"
        ],
        "reason": "Prompt uses combined 'YES / NO' form"
      },
      "stage6": {
        "tokens": [
          "Review Report"
        ],
        "reason": "Token appears in input packets, not in prompt"
      }
    },
    "contract_prefixes_absent_in_agnostic": {
      "stage3": {
        "prefixes": [
          "DEC-"
        ],
        "reason": "Decision contracts are domain-specific; injected by compiled domain packs"
      }
    },
    "stage_checks_relaxed_in_agnostic": {
      "stage5": {
        "checks": [
          "final_disposition_position"
        ],
        "reason": "Initial Greeting follows FINAL_DISPOSITION section, pushing it outside the 500-char tail window"
      }
    },
    "validator_guidance": "When validating agnostic templates, skip tokens listed in frozen_tokens_absent_in_agnostic, skip prefixes listed in contract_prefixes_absent_in_agnostic, and relax checks listed in stage_checks_relaxed_in_agnostic."
  },
